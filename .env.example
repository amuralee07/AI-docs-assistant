# AI Docs Assistant - Environment variables
# Copy to .env and customize

# Server
HOST=0.0.0.0
PORT=8000

# RAG settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# Optional: OpenAI for answer generation (leave empty for retrieval-only)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
